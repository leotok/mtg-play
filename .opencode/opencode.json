{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@mohak34/opencode-notifier@latest"],
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "git rm *": "deny",
      "git reset *": "deny",
      "git stash *": "deny",
      "git checkout *": "deny"
    }
  }
}